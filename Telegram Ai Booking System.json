      "parameters": {
        "jsCode": "const text = $node[\"Telegram Trigger\"].json[\"message\"][\"text\"] || '';\n\nlet customer_name = '';\nlet email = '';\nlet preferred_date = '';\nlet preferred_time = '';\nlet selected_service = '';\n\n// Flexible regex - handles spaces around = and case insensitive\ntry { customer_name = text.match(/name\\s*=\\s*([^,\\n]+)/i)[1].trim(); } catch(e) { customer_name = ''; }\ntry { email = text.match(/email\\s*=\\s*([^,\\n]+)/i)[1].trim(); } catch(e) { email = ''; }\ntry { preferred_date = text.match(/date\\s*=\\s*([^,\\n]+)/i)[1].trim(); } catch(e) { preferred_date = ''; }\ntry { preferred_time = text.match(/time\\s*=\\s*([^,\\n]+)/i)[1].trim(); } catch(e) { preferred_time = ''; }\ntry { selected_service = text.match(/book\\s+([^,\\n]+)/i)[1].trim(); } catch(e) { selected_service = ''; }\n\nconst chat_id = String($node[\"Telegram Trigger\"].json[\"message\"][\"chat\"][\"id\"]);\n\nconst missing = [];\nif (!customer_name) missing.push('name');\nif (!email) missing.push('email');\nif (!preferred_date) missing.push('date');\nif (!preferred_time) missing.push('time');\nif (!selected_service) missing.push('service');\n\nconst now = new Date();\nconst bookingRef = 'BK' + now.getFullYear() + String(now.getMonth()+1).padStart(2,'0') + String(now.getDate()).padStart(2,'0') + String(now.getHours()).padStart(2,'0') + String(now.getMinutes()).padStart(2,'0');\n\nreturn [{\n  json: {\n    customer_name,\n    email,\n    preferred_date,\n    preferred_time,\n    selected_service,\n    chat_id,\n    booking_ref: bookingRef,\n    is_valid: missing.length === 0,\n    missing_fields: missing.join(', ')\n  }\n}];"
      },
